# Firebase web SDK config (browser-bundled — values are public, but committed
# placeholders only). Get real values from the Firebase console for your project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Web-application OAuth client_id used by chrome.identity.launchWebAuthFlow.
# In Google Cloud Console:
#   - Application type: "Web application" (NOT "Chrome App")
#   - Authorized redirect URIs MUST include exactly:
#       https://<EXT_ID>.chromiumapp.org/
#     (trailing slash is required; that is what
#     chrome.identity.getRedirectURL() returns)
#   - <EXT_ID> is the prod extension ID. Dev unpacked builds share the same
#     ID via VITE_EXTENSION_KEY below, so a single redirect URI covers both.
VITE_GOOGLE_OAUTH_WEB_CLIENT_ID=

# OPTIONAL but strongly recommended for unpacked local dev. Pinning the
# extension to the prod ID makes two things line up:
#   1. The deployed webapp's chrome.runtime.sendMessage(EXT_ID, ...) reaches
#      your unpacked build — the webapp hardcodes the prod EXT_ID (see
#      commentarium/src/app/_lib/surface.ts:5).
#   2. chrome.identity.getRedirectURL() returns the redirect URI that's
#      authorized in Google Cloud Console for the shared Web OAuth client.
#      Without VITE_EXTENSION_KEY your local EXT_ID is random and Google
#      rejects the OAuth flow with redirect_uri_mismatch.
# Alternative for (2) only: register your local <EXT_ID>.chromiumapp.org/
# as an additional authorized redirect URI in Cloud Console. Pinning is
# simpler when only the team's dev machines need to OAuth.
#
# THIS IS A PUBLIC KEY, not a private key. The manifest "key" field is the
# base64 encoding of the SubjectPublicKeyInfo (DER) for the extension's RSA
# keypair — derivable from the private .pem via:
#   openssl rsa -in <key>.pem -pubout -outform DER 2>/dev/null | openssl base64 -A
# but for THIS extension, the canonical value is whatever was previously
# committed at manifest.ts and now lives in the team's private build-config doc.
# DO NOT paste the contents of any .pem (private key) file here — that would
# be a credential leak, not a config value.
#
# Production Web Store publishes leave this UNSET (the Web Store assigns the
# ID). The new `npm run build:release` script enforces this regardless of
# what's in your .env.local.
VITE_EXTENSION_KEY=
